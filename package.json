{
  "private": true,
  "name": "j16z",
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "pnpm --recursive --parallel --filter \"./apps/*\" run dev",
    "dev:fe": "pnpm --filter j16z-frontend run dev",
    "dev:be": "bash apps/api/scripts/dev.sh",
    "build": "pnpm --recursive --filter \"./packages/*\" run build && pnpm --recursive --parallel --filter \"./apps/*\" run build",
    "test": "vitest",
    "test:be": "pnpm --filter @j16z/api run test",
    "lint": "biome check",
    "lint:fix": "biome check --write --unsafe",
    "check": "tsc -b tsconfig.json",
    "infra:up": "docker compose -f docker-compose.test.yml up -d",
    "infra:down": "docker compose -f docker-compose.test.yml down",
    "db:migrate": "pnpm --filter @j16z/api run db:migrate",
    "db:generate": "pnpm --filter @j16z/api run db:generate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.2",
    "vitest": "^4.0.2"
  }
}
