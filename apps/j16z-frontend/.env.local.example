# J16Z Frontend Environment Variables
# Copy this file to .env.local and fill in the values.

# ---------------------------------------------------------------------------
# Mock data mode — set to "true" to use local mock data during development.
# Set to "false" to call the real Hono API backend.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_USE_MOCK_DATA=true

# ---------------------------------------------------------------------------
# Supabase — required when NEXT_PUBLIC_USE_MOCK_DATA=false
# Get these from: Supabase Dashboard -> Project Settings -> API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ---------------------------------------------------------------------------
# API Base URL — Hono API server
# Development: http://localhost:3001
# Production: https://api.your-domain.com
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
